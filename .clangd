Diagnostics:
    UnusedIncludes: Strict

CompileFlags:
  Add: -DIS_CLANGD -std=c++20
---
If:
    PathMatch: .*_test.cc

Diagnostics:
    ClangTidy:
        Remove: [cppcoreguidelines-avoid-non-const-global-variables, cppcoreguidelines-owning-memory]

---
If:
    PathMatch: .*[.]mope

Diagnostics:
    Suppress: '*'
